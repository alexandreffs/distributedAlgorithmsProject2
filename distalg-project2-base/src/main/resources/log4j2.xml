<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="INFO" shutdownHook="disable">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
           <PatternLayout
				pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n" />
        </Console>

		<File name="msglog" fileName="application.log"
			immediateFlush="true"
			append="false">
			<PatternLayout
				pattern="%d{UNIX_MILLIS} %msg%n" />
		</File>

    </Appenders>

    <Loggers>

        <Logger level="info" name="io.netty"/>
        <Logger level="info" name="pt.unl.fct.di.novasys.network"/>
        <Logger level="info" name="pt.unl.fct.di.novasys.channel"/>
        <Logger level="info" name="pt.unl.fct.di.novasys.babel"/>

		<Logger name="protocols." level="info" additivity="true">
			<AppenderRef ref="msglog" />
		</Logger>

        <Root level="debug">
            <AppenderRef ref="Console" level="info"/>
        </Root>
    </Loggers>

</Configuration>
